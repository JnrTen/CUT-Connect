{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "age": { "type": "integer" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "personalityTraits": { "type": "array", "items": { "type": "string" } },
        "isSubscribed": { "type": "boolean" },
        "subscriptionType": { "type": "string" },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string", "format": "url" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "blockedUsers": { "type": "array", "items": { "type": "string" } },
        "preferences": {
          "type": "object",
          "properties": {
            "gender": { "type": "string", "enum": ["male", "female", "other", "any"] },
            "minAge": { "type": "integer" },
            "maxAge": { "type": "integer" },
            "interests": { "type": "array", "items": { "type": "string" } },
            "personalityTraits": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Match": {
      "title": "Match",
      "description": "A connection between two users",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Public student profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "age": { "type": "integer" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "personalityTraits": { "type": "array", "items": { "type": "string" } },
        "photoURL": { "type": "string", "format": "url" }
      },
      "required": ["uid", "displayName"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A payment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string", "format": "url" },
        "imageUrl": { "type": "string", "format": "url" },
        "caption": { "type": "string" },
        "likes": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "imageUrl", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "A short-lived story",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string", "format": "url" },
        "imageUrl": { "type": "string", "format": "url" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles (private)"
    },
    "/profiles/{profileId}": {
      "schema": "Profile",
      "description": "Public student profiles"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Matches between users"
    },
    "/matches/{matchId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a match"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Subscription records"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social media posts"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "User stories"
    }
  }
}
